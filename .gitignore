cd ~/share
cat > .gitignore << 'EOF'
# 编译产物
*.exe
*.out
*.o
*.obj
*.a
*.so
*.dll
*.dylib

# CMake / Makefile 构建目录
cmake-build-*/
build/
build-*/
out/
bin/
lib/

# IDE 配置
.idea/
*.iml
.vscode/
*.swp
*.swo
*~

# 调试符号
*.dSYM/
*.su
*.idb
*.pdb

# 依赖管理
vcpkg_installed/
conanbuildinfo.*
conan.lock

# 日志与临时文件
*.log
*.tmp
*.temp
.DS_Store
Thumbs.db

# 测试数据
*.csv
*.dat
._*